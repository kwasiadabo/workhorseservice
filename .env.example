# Copy this file to .env and fill in real values. Never commit .env itself.

NODE_ENV=development
PORT=5000
APP_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Database (Microsoft SQL Server via tedious) — leave blank to boot without a
# DB connection (DB-dependent routes will fail; see GET /health).
DB_DIALECT=mssql
DB_HOST=
DB_PORT=1433
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false

# JWT — generate real, unique values for any non-local environment, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Production refuses to boot if these are left at their dev defaults.
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=10

# Mail (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=VX-Workhorse <no-reply@example.com>

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# Default Super Admin (created by the seeder — change immediately after first run)
SUPER_ADMIN_EMAIL=admin@platform.local
SUPER_ADMIN_PASSWORD=ChangeMe123!

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# Nalo Solutions SMS
NALO_API_KEY=
NALO_SENDER_ID=WorkHorse
NALO_API_URL=

# Error tracking (Sentry) — leave blank to keep error tracking inactive.
SENTRY_DSN=

# Set to false on all but one instance if running more than one API process
# (the SMS-dispatch cron has no distributed lock — see src/scheduler.js).
SCHEDULER_ENABLED=true
